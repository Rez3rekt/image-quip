# Baked into the client at webpack build time (Vercel: Project → Settings → Environment Variables).
# HTTPS API origin, no trailing slash (must match where your Node/Socket.IO server is reachable).
REACT_APP_SERVER_URL=https://your-api.example.com

# Optional: only if static files are served from a different origin than the socket/API.
# REACT_APP_SERVER_BASE_URL=https://cdn.example.com

# Optional: lobby loop file name under the server /audio/ route.
# REACT_APP_LOBBY_MUSIC_FILE=lobby-loop.mp3
