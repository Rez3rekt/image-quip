# Production Environment Variables for Chirped
# Copy this file to .env.production and fill in your actual values

# Database Configuration
POSTGRES_PASSWORD=your_secure_database_password_here

# Security
JWT_SECRET=your_very_long_secure_jwt_secret_at_least_64_characters_long

# URLs (replace with your actual domain)
FRONTEND_URL=https://your-domain.com
API_URL=https://your-domain.com/api

# Application Settings
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Database URL (auto-generated, don't change)
DATABASE_URL=postgresql://chirped_user:${POSTGRES_PASSWORD}@postgres:5432/chirped_production

# Redis URL (auto-generated, don't change)
REDIS_URL=redis://redis:6379 